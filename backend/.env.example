# Football-Data.org API key — get a free one at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Competition to track (WC = FIFA World Cup)
COMPETITION_CODE=WC

# Hour of day (0-23, server local time) to run the daily refresh
REFRESH_HOUR=4

# Token required to call POST /api/admin/refresh
ADMIN_TOKEN=change-me

# SQLite database location
DATABASE_URL=sqlite:///./wc.db

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
